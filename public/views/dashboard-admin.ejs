<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Dashboard — Inc.5 Repair Portal</title>
  <link rel="stylesheet" href="/css/job-creation.css">
  <link rel="stylesheet" href="/css/dashboard-admin.css">
  <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.2/dist/chart.umd.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/jspdf@2.5.1/dist/jspdf.umd.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/html2canvas@1.4.1/dist/html2canvas.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/xlsx@0.18.5/dist/xlsx.full.min.js"></script>
</head>
<body>

  <div id="pageLoader" class="page-loader">
    <div class="loader-spinner"></div>
    <p>Loading...</p>
  </div>

  <div class="dashboard-container">
    <nav class="navbar">
      <div class="nav-brand">
        <img src="/uploads/Inc5_White.png" alt="Inc.5" class="nav-brand-logo" onerror="this.src='/uploads/Inc5_White.png'; this.style.height='36px';" />
      </div>
      <div class="nav-tabs">
        <% const normalizedRole = (role || '').toLowerCase().trim(); const isAdmin = normalizedRole === 'admin'; const isDashboard = normalizedRole === 'dashboard'; const isRMRole = normalizedRole === 'rm'; %>
        <% if (isAdmin) { %>
          <a href="/job-creation" class="nav-tab">Job Creation</a>
          <a href="/action-analytics" class="nav-tab">Action & Analytics</a>
          <a href="/dashboard-admin" class="nav-tab active">Dashboard</a>
        <% } else if (isDashboard || isRMRole) { %>
          <a href="/dashboard-admin" class="nav-tab active">Dashboard</a>
        <% } %>
      </div>
      <div class="nav-user">
        <span class="user-info">
          <span class="user-icon-wrap"><svg class="user-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm0 3c1.66 0 3 1.34 3 3s-1.34 3-3 3-3-1.34-3-3 1.34-3 3-3zm0 14.2c-2.5 0-4.71-1.28-6-3.22.03-1.99 4-3.08 6-3.08 1.99 0 5.97 1.09 6 3.08-1.29 1.94-3.5 3.22-6 3.22z"/></svg></span>
          <span class="user-name-wrap"><span class="user-id-text"><%= userId %></span><span class="role-badge-default"><%= role || 'No Role' %></span></span>
        </span>
        <button id="logoutBtn" class="logout-btn"><svg class="logout-btn-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"><path d="M17 7l-1.41 1.41L18.17 11H8v2h10.17l-2.58 2.58L17 17l5-5-5-5zM4 5h8V3H4c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h8v-2H4V5z"/></svg>Logout</button>
      </div>
    </nav>

    <main class="main-content da-main">
      <div class="da-header">
        <div class="da-header-left">
          <h1 class="da-title">Operations Dashboard</h1>
          <p class="da-subtitle">Real-time repair job monitoring</p>
        </div>
        <div class="da-header-right">
          <button class="da-action-btn" id="downloadAllGraphsBtn" title="Download All Graphs as PDF">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" width="14" height="14"><path d="M19 9h-4V3H9v6H5l7 7 7-7zM5 18v2h14v-2H5z"/></svg> Graphs PDF
          </button>
          <button class="da-action-btn" id="downloadRawDataBtn" title="Download Raw Data as Excel">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" width="14" height="14"><path d="M14 2H6c-1.1 0-2 .9-2 2v16c0 1.1.9 2 2 2h12c1.1 0 2-.9 2-2V8l-6-6zm2 16H8v-2h8v2zm0-4H8v-2h8v2zm-3-5V3.5L18.5 9H13z"/></svg> Raw Data
          </button>

          <div class="da-filter-group">
            <label for="daMonthFilter">Month</label>
            <select id="daMonthFilter">
              <option value="all">All Months</option>
              <option value="1">Jan</option><option value="2">Feb</option><option value="3">Mar</option><option value="4">Apr</option>
              <option value="5">May</option><option value="6">Jun</option><option value="7">Jul</option><option value="8">Aug</option>
              <option value="9">Sep</option><option value="10">Oct</option><option value="11">Nov</option><option value="12">Dec</option>
            </select>
          </div>
          <div class="da-filter-group">
            <label for="daYearFilter">Year</label>
            <select id="daYearFilter"><option value="all">All Years</option></select>
          </div>
          <div class="da-filter-group">
            <label>Store</label>
            <div class="da-search-select" id="storeDropdown">
              <div class="da-ss-selected" id="storeSelected"><span class="da-ss-text">All Stores</span><svg class="da-ss-arrow" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor"><path d="M7 10l5 5 5-5z"/></svg></div>
              <div class="da-ss-panel" id="storePanel">
                <div class="da-ss-search-wrap"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor"><path d="M15.5 14h-.79l-.28-.27A6.471 6.471 0 0 0 16 9.5 6.5 6.5 0 1 0 9.5 16c1.61 0 3.09-.59 4.23-1.57l.27.28v.79l5 4.99L20.49 19l-4.99-5zm-6 0C7.01 14 5 11.99 5 9.5S7.01 5 9.5 5 14 7.01 14 9.5 11.99 14 9.5 14z"/></svg><input type="text" id="storeSearchInput" placeholder="Search store..." autocomplete="off"></div>
                <div class="da-ss-list" id="storeList"></div>
              </div>
            </div>
            <input type="hidden" id="daStoreFilter" value="all">
          </div>
          <div class="da-filter-group" id="warehouseFilterGroup">
            <label>Warehouse</label>
            <div class="da-search-select" id="warehouseDropdown">
              <div class="da-ss-selected" id="warehouseSelected"><span class="da-ss-text">All Warehouses</span><svg class="da-ss-arrow" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor"><path d="M7 10l5 5 5-5z"/></svg></div>
              <div class="da-ss-panel" id="warehousePanel">
                <div class="da-ss-search-wrap"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor"><path d="M15.5 14h-.79l-.28-.27A6.471 6.471 0 0 0 16 9.5 6.5 6.5 0 1 0 9.5 16c1.61 0 3.09-.59 4.23-1.57l.27.28v.79l5 4.99L20.49 19l-4.99-5zm-6 0C7.01 14 5 11.99 5 9.5S7.01 5 9.5 5 14 7.01 14 9.5 11.99 14 9.5 14z"/></svg><input type="text" id="warehouseSearchInput" placeholder="Search warehouse..." autocomplete="off"></div>
                <div class="da-ss-list" id="warehouseList"></div>
              </div>
            </div>
            <input type="hidden" id="daWarehouseFilter" value="all">
          </div>
          <button class="da-refresh-btn" id="daRefreshBtn"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor"><path d="M17.65 6.35A7.958 7.958 0 0 0 12 4c-4.42 0-7.99 3.58-7.99 8s3.57 8 7.99 8c3.73 0 6.84-2.55 7.73-6h-2.08A5.99 5.99 0 0 1 12 18c-3.31 0-6-2.69-6-6s2.69-6 6-6c1.66 0 3.14.69 4.22 1.78L13 11h7V4l-2.35 2.35z"/></svg> Refresh</button>
          <div class="da-last-updated" id="daLastUpdated">—</div>
        </div>
      </div>

      <div class="da-kpi-strip" id="daKpiStrip">
        <div class="da-kpi-card"><div class="da-kpi-bar" style="background:var(--red);"></div><div class="da-kpi-icon">⚙️</div><div class="da-kpi-body"><div class="da-kpi-value" id="kpiActive">—</div><div class="da-kpi-label">Active Jobs</div></div></div>
        <div class="da-kpi-card"><div class="da-kpi-bar" style="background:var(--green);"></div><div class="da-kpi-icon">✅</div><div class="da-kpi-body"><div class="da-kpi-value" id="kpiClosed">—</div><div class="da-kpi-label">Closed Jobs</div></div></div>
        <div class="da-kpi-card"><div class="da-kpi-bar" style="background:var(--amber);"></div><div class="da-kpi-icon">⏱️</div><div class="da-kpi-body"><div class="da-kpi-value" id="kpiTat">—</div><div class="da-kpi-label">Avg TAT (Days)</div></div></div>
        <div class="da-kpi-card"><div class="da-kpi-bar" style="background:var(--teal);"></div><div class="da-kpi-icon">🔧</div><div class="da-kpi-body"><div class="da-kpi-value" id="kpiRepaired">—</div><div class="da-kpi-label">Vendor Repaired</div></div></div>
        <div class="da-kpi-card"><div class="da-kpi-bar" style="background:#e05c2a;"></div><div class="da-kpi-icon">🔄</div><div class="da-kpi-body"><div class="da-kpi-value" id="kpiReplaced">—</div><div class="da-kpi-label">Vendor Replaced</div></div></div>
        <div class="da-kpi-card"><div class="da-kpi-bar" style="background:var(--purple);"></div><div class="da-kpi-icon">📋</div><div class="da-kpi-body"><div class="da-kpi-value" id="kpiTotal">—</div><div class="da-kpi-label">Total Jobs</div></div></div>
      </div>

      <div class="da-charts-grid" id="chartsGrid">
        <div class="da-chart-card" id="card-trend"><div class="da-chart-header"><div><div class="da-chart-title">Jobs Over Time</div><div class="da-chart-sub">Daily job creation trend</div></div><div class="da-chart-actions"><button class="da-chart-dl-btn" data-chart="chartJobsTrend" title="Download PDF">⬇</button><button class="da-chart-fs-btn" data-card="card-trend" title="Fullscreen">⛶</button></div></div><div class="da-chart-body"><canvas id="chartJobsTrend"></canvas></div></div>
        <div class="da-chart-card" id="card-status"><div class="da-chart-header"><div><div class="da-chart-title">Status Distribution</div><div class="da-chart-sub">Current status breakdown</div></div><div class="da-chart-actions"><button class="da-chart-dl-btn" data-chart="chartStatusDonut" title="Download PDF">⬇</button><button class="da-chart-fs-btn" data-card="card-status" title="Fullscreen">⛶</button></div></div><div class="da-chart-body da-chart-body-center"><canvas id="chartStatusDonut"></canvas></div><div class="da-legend" id="legendStatus"></div></div>
        <div class="da-chart-card" id="card-repair"><div class="da-chart-header"><div><div class="da-chart-title">Repair vs Replacement</div><div class="da-chart-sub">Vendor decision outcome</div></div><div class="da-chart-actions"><button class="da-chart-dl-btn" data-chart="chartRepairPie" title="Download PDF">⬇</button><button class="da-chart-fs-btn" data-card="card-repair" title="Fullscreen">⛶</button></div></div><div class="da-chart-body da-chart-body-center"><canvas id="chartRepairPie"></canvas></div><div class="da-legend" id="legendRepair"></div></div>
        <div class="da-chart-card" id="card-tat"><div class="da-chart-header"><div><div class="da-chart-title">Avg TAT Trend</div><div class="da-chart-sub">Average turnaround time (days)</div></div><div class="da-chart-actions"><button class="da-chart-dl-btn" data-chart="chartTatTrend" title="Download PDF">⬇</button><button class="da-chart-fs-btn" data-card="card-tat" title="Fullscreen">⛶</button></div></div><div class="da-chart-body"><canvas id="chartTatTrend"></canvas></div></div>
        <div class="da-chart-card" id="card-barcode"><div class="da-chart-header"><div><div class="da-chart-title">Top Barcodes</div><div class="da-chart-sub">Most recurring barcodes</div></div><div class="da-chart-actions"><button class="da-chart-dl-btn" data-chart="chartBarcode" title="Download PDF">⬇</button><button class="da-chart-fs-btn" data-card="card-barcode" title="Fullscreen">⛶</button></div></div><div class="da-chart-body"><canvas id="chartBarcode"></canvas></div></div>
        <div class="da-chart-card" id="card-itemid"><div class="da-chart-header"><div><div class="da-chart-title">Top Item IDs</div><div class="da-chart-sub">Most recurring items</div></div><div class="da-chart-actions"><button class="da-chart-dl-btn" data-chart="chartItemId" title="Download PDF">⬇</button><button class="da-chart-fs-btn" data-card="card-itemid" title="Fullscreen">⛶</button></div></div><div class="da-chart-body"><canvas id="chartItemId"></canvas></div></div>
      </div>
    </main>
  </div>

  <!-- Fullscreen Modal -->
  <div id="fsModal" class="da-fs-modal hidden">
    <div class="da-fs-modal-header">
      <span id="fsModalTitle"></span>
      <button id="fsModalClose" class="da-fs-modal-close">✕</button>
    </div>
    <div class="da-fs-modal-body" id="fsModalBody"></div>
  </div>

  <script>window.DA_ROLE = "<%= (role || '').toLowerCase().trim() %>";</script>
  <script src="/js/dashboard.js"></script>
  <script src="/js/dashboard-admin.js"></script>
</body>
</html>