<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Action & Analytics — Inc.5 Repair Portal</title>
  <link rel="stylesheet" href="/css/job-creation.css">
  <link rel="stylesheet" href="/css/action-analytics.css">
</head>
<body>

  <div id="pageLoader" class="page-loader">
    <div class="loader-spinner"></div>
    <p>Loading...</p>
  </div>

  <div class="dashboard-container">

    <!-- ══ NAVBAR ══ -->
    <nav class="navbar">
      <div class="nav-brand">
        <img src="/uploads/Inc5_nav_logo.png"
     alt="Inc.5"
     class="nav-brand-logo"
     onerror="this.src='/uploads/Inc5_White.png';" />
      </div>

      <div class="nav-tabs">
        <%
          const normalizedRole = (role || '').toLowerCase().trim();
          const isStore     = normalizedRole === 'store';
          const isWarehouse = normalizedRole.includes('warehouse');
          const isAdmin     = normalizedRole === 'admin';
        %>
        <% if (isStore) { %>
          <a href="/job-creation"     class="nav-tab">Job Creation</a>
          <a href="/action-analytics" class="nav-tab active">Action & Analytics</a>
        <% } else if (isAdmin) { %>
          <a href="/job-creation"     class="nav-tab">Job Creation</a>
          <a href="/action-analytics" class="nav-tab active">Action & Analytics</a>
          <a href="/dashboard-admin"  class="nav-tab">Dashboard</a>
        <% } else if (isWarehouse) { %>
          <a href="/action-analytics" class="nav-tab active">Action & Analytics</a>
        <% } %>
      </div>

      <div class="nav-user">
        <span class="user-info">
          <span class="user-icon-wrap">
            <svg class="user-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
              <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12
                       2zm0 3c1.66 0 3 1.34 3 3s-1.34 3-3 3-3-1.34-3-3 1.34-3 3-3zm0
                       14.2c-2.5 0-4.71-1.28-6-3.22.03-1.99 4-3.08 6-3.08 1.99 0 5.97
                       1.09 6 3.08-1.29 1.94-3.5 3.22-6 3.22z"/>
            </svg>
          </span>
          <span class="user-name-wrap">
            <span class="user-id-text"><%= userId %></span>
            <span class="role-badge-default"><%= role || 'No Role' %></span>
          </span>
        </span>
        <button id="logoutBtn" class="logout-btn">
          <svg class="logout-btn-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
            <path d="M17 7l-1.41 1.41L18.17 11H8v2h10.17l-2.58 2.58L17 17l5-5-5-5zM4
                     5h8V3H4c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h8v-2H4V5z"/>
          </svg>
          Logout
        </button>
      </div>
    </nav>

    <main class="main-content aa-main">

      <!-- ── FILTER BAR ── -->
      <div class="aa-filter-bar">
        <div class="filter-group">
          <label for="statusFilter">Status</label>
          <select id="statusFilter">
            <option value="all">All Status</option>
            <% statuses.forEach(function(s) { %>
              <option value="<%= s %>"><%= s %></option>
            <% }) %>
          </select>
        </div>

        <div class="filter-divider"></div>

        <div class="filter-group">
          <label for="monthFilter">Month</label>
          <select id="monthFilter">
            <option value="all">All Months</option>
            <option value="1">Jan</option><option value="2">Feb</option>
            <option value="3">Mar</option><option value="4">Apr</option>
            <option value="5">May</option><option value="6">Jun</option>
            <option value="7">Jul</option><option value="8">Aug</option>
            <option value="9">Sep</option><option value="10">Oct</option>
            <option value="11">Nov</option><option value="12">Dec</option>
          </select>
        </div>

        <div class="filter-group">
          <label for="yearFilter">Year</label>
          <select id="yearFilter">
            <option value="all">All Years</option>
          </select>
        </div>

        <div class="filter-divider"></div>

        <div class="filter-group filter-search">
          <label for="searchInput">Search</label>
          <div class="search-wrap">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor">
              <path d="M15.5 14h-.79l-.28-.27A6.471 6.471 0 0 0 16 9.5 6.5 6.5 0 1 0
                       9.5 16c1.61 0 3.09-.59 4.23-1.57l.27.28v.79l5 4.99L20.49 19
                       l-4.99-5zm-6 0C7.01 14 5 11.99 5 9.5S7.01 5 9.5 5 14 7.01 14
                       9.5 11.99 14 9.5 14z"/>
            </svg>
            <input type="text" id="searchInput"
                   placeholder="Search Job ID, Customer, Phone, AWB…">
          </div>
        </div>

        <button class="btn-refresh" id="refreshBtn">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor">
            <path d="M17.65 6.35A7.958 7.958 0 0 0 12 4c-4.42 0-7.99 3.58-7.99 8s3.57 8
                     7.99 8c3.73 0 6.84-2.55 7.73-6h-2.08A5.99 5.99 0 0 1 12 18c-3.31
                     0-6-2.69-6-6s2.69-6 6-6c1.66 0 3.14.69 4.22 1.78L13 11h7V4
                     l-2.35 2.35z"/>
          </svg>
          Refresh
        </button>
      </div>

      <!-- ── KPI STRIP ── -->
      <div class="kpi-strip">
        <div class="kpi-card">
          <div class="kpi-icon">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
              <path d="M19 3H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm-7 3c1.93 0 3.5 1.57 3.5 3.5S13.93 13 12 13s-3.5-1.57-3.5-3.5S10.07 6 12 6zm7 13H5v-.23c0-.62.28-1.2.76-1.58C7.47 15.82 9.64 15 12 15s4.53.82 6.24 2.19c.48.38.76.97.76 1.58V19z"/>
            </svg>
          </div>
          <div class="kpi-text">
            <div class="kpi-label">Total</div>
            <div class="kpi-value" id="kpiTotal">—</div>
          </div>
        </div>
        <div class="kpi-card kpi-closed">
          <div class="kpi-icon">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
              <path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z"/>
            </svg>
          </div>
          <div class="kpi-text">
            <div class="kpi-label">Closed</div>
            <div class="kpi-value" id="kpiClosed">—</div>
          </div>
        </div>
        <div class="kpi-card kpi-pending">
          <div class="kpi-icon">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
              <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm0 15c-.55 0-1-.45-1-1v-4c0-.55.45-1 1-1s1 .45 1 1v4c0 .55-.45 1-1 1zm1-8h-2V7h2v2z"/>
            </svg>
          </div>
          <div class="kpi-text">
            <div class="kpi-label">Pending</div>
            <div class="kpi-value" id="kpiPending">—</div>
          </div>
        </div>
        <span class="kpi-meta" id="kpiMeta"></span>
      </div>

      <!-- ── TABLE ── -->
      <div class="aa-table-wrap">
        <table class="aa-table">
          <thead>
            <tr>
              <th>Job ID</th>
              <th>Phone</th>
              <th>Customer</th>
              <th>Store ID</th>
              <th>Item ID</th>
              <th>Under 90</th>
              <th>Delivery Date</th>
              <th>Status</th>
              <th>Closed Date</th>
              <th>Attachment</th>
              <th>WH / Vendor Timeline</th>
              <th>Action</th>
              <% if (isAdmin) { %>
                <th>Admin</th>
              <% } %>
            </tr>
          </thead>
          <tbody id="jobTableBody">
            <tr>
              <td colspan="<%= isAdmin ? 13 : 12 %>" class="table-loading">
                Loading jobs…
              </td>
            </tr>
          </tbody>
        </table>

        <!-- Empty state template — JS can clone & insert when 0 results -->
        <template id="emptyStateTpl">
          <tr class="table-empty">
            <td colspan="<%= isAdmin ? 13 : 12 %>">
              <div class="empty-state">
                <div class="empty-state-icon">
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
                    <path d="M20 6h-2.18c.07-.44.18-.88.18-1.36C18 2.51 15.86.36 13.14.36c-1.42 0-2.67.6-3.57 1.55L8 3.5 6.43 1.91C5.53.96 4.28.36 2.86.36 .14.36-2 2.51-2 4.64c0 .48.11.92.18 1.36H-2c-1.1 0-2 .9-2 2v12c0 1.1.9 2 2 2h22c1.1 0 2-.9 2-2V8c0-1.1-.9-2-2-2z"/>
                  </svg>
                </div>
                <div class="empty-state-title">No jobs found</div>
                <div class="empty-state-sub">Try adjusting your filters or search query</div>
              </div>
            </td>
          </tr>
        </template>
      </div>

    </main>
  </div>

  <!-- ════════════════════════════════════════
       ADMIN EDIT MODAL
  ════════════════════════════════════════ -->
  <% if (isAdmin) { %>
  <div id="adminEditModal" class="modal-overlay hidden">
    <div class="modal-box modal-box-lg">
      <div class="modal-header">
        <span>Edit Ticket</span>
        <button type="button" class="modal-close" id="closeAdminEditModal">✕</button>
      </div>
      <div class="modal-body" style="gap:10px;">
        <p class="modal-job-id" id="adminEditJobId">Job: —</p>
        <div class="admin-grid">
          <div class="wh-form-row"><label>Customer Number</label><input type="text" id="ae_CustomerNumber"></div>
          <div class="wh-form-row"><label>Customer Name</label><input type="text" id="ae_CustomerName"></div>
          <div class="wh-form-row"><label>Store ID</label><input type="text" id="ae_Store_Id"></div>
          <div class="wh-form-row"><label>Item ID</label><input type="text" id="ae_ITEM_ID"></div>
          <div class="wh-form-row"><label>Under 90 Days</label><input type="text" id="ae_ProductUnder90Days"></div>
          <div class="wh-form-row"><label>Delivery Date</label><input type="date" id="ae_DeliveryDate"></div>
          <div class="wh-form-row"><label>Status</label><input type="text" id="ae_Status" placeholder="Open / Pending / Sent to Warehouse…"></div>
          <div class="wh-form-row"><label>Ticket Closing Date</label><input type="text" id="ae_Ticket_Closing_Date" placeholder="YYYY-MM-DD HH:MM:SS"></div>
          <div class="wh-form-row"><label>Warehouse ID</label><input type="text" id="ae_WarehouseID"></div>
          <div class="wh-form-row"><label>Warehouse Name</label><input type="text" id="ae_WarehouseName"></div>
          <div class="wh-form-row"><label>Courier Name</label><input type="text" id="ae_CourierName"></div>
          <div class="wh-form-row"><label>AWB</label><input type="text" id="ae_AWB"></div>
          <div class="wh-form-row"><label>Dispatch Date</label><input type="date" id="ae_DispatchDate"></div>
          <div class="wh-form-row"><label>Warehouse Receive Date</label><input type="text" id="ae_Warehouse_Receive_Date" placeholder="YYYY-MM-DD HH:MM:SS"></div>
          <div class="wh-form-row"><label>Warehouse Remarks</label><textarea id="ae_WarehouseRemarks"></textarea></div>
          <div class="wh-form-row"><label>Warehouse Sent Date</label><input type="text" id="ae_Warehouse_Sent_Date" placeholder="YYYY-MM-DD HH:MM:SS"></div>
          <div class="wh-form-row"><label>Vendor Name</label><input type="text" id="ae_Vendor_Name"></div>
          <div class="wh-form-row"><label>Vendor AWB</label><input type="text" id="ae_Vendor_Awb"></div>
          <div class="wh-form-row"><label>Gate Pass No</label><input type="text" id="ae_Gate_Pass_No"></div>
          <div class="wh-form-row"><label>Vendor Sent Date</label><input type="date" id="ae_Vendor_Sent_Date"></div>
          <div class="wh-form-row"><label>Vendor Decision</label><input type="text" id="ae_Vendor_Decision" placeholder="Repaired / Replaced…"></div>
          <div class="wh-form-row"><label>Vendor Decision Date</label><input type="date" id="ae_Vendor_Decision_Date"></div>
          <div class="wh-form-row"><label>Store Sent Date</label><input type="text" id="ae_Store_Sent_Date" placeholder="YYYY-MM-DD HH:MM:SS"></div>
          <div class="wh-form-row"><label>Store Received Date</label><input type="text" id="ae_Store_Received_Date" placeholder="YYYY-MM-DD HH:MM:SS"></div>
          <div class="wh-form-row"><label>Closing Remarks</label><textarea id="ae_Closing_Ticket_Remarks"></textarea></div>
          <div class="wh-form-row" style="grid-column: 1/-1;">
            <label>Admin Note (why edit?) <span class="req">*</span></label>
            <input type="text" id="ae_AdminNote" placeholder="e.g. corrected delivery date as per call">
          </div>
        </div>
        <div id="adminEditError" class="modal-error hidden"></div>
      </div>
      <div class="modal-footer">
        <button class="btn-primary" id="saveAdminEditBtn">Save Changes</button>
        <button class="btn-secondary" id="cancelAdminEditBtn">Cancel</button>
      </div>
    </div>
  </div>
  <% } %>

  <!-- ════════════════════════════════════════
       STORE MODALS
  ════════════════════════════════════════ -->
  <% if (isStore) { %>
  <div id="whTransferModal" class="modal-overlay hidden">
    <div class="modal-box modal-box-wh">
      <div class="modal-header">
        <span>Transfer to Warehouse</span>
        <button type="button" class="modal-close" id="closeWhTransferModal">✕</button>
      </div>
      <form id="whTransferForm" enctype="multipart/form-data">
        <div class="modal-body wh-modal-body">
          <p class="modal-job-id" id="whTransferJobId"></p>
          <div class="wh-form-row">
            <label for="wh_warehouse_id">Select Warehouse <span class="req">*</span></label>
            <select id="wh_warehouse_id" name="warehouse_id" required>
              <option value="">Select Warehouse</option>
              <% warehouses.forEach(function(w) { %>
                <option value="<%= w.WhID %>" data-whid="<%= w.WhID %>" data-name="<%= w.WarehouseName %>">
                  <%= w.WhID %> - <%= w.WarehouseName %>
                </option>
              <% }) %>
            </select>
            <input type="hidden" id="wh_warehouse_name" name="warehouse_name">
          </div>
          <div class="wh-form-row">
            <label for="wh_courier_name">Select Courier</label>
            <select id="wh_courier_name" name="courier_name">
              <option value="">Select Courier</option>
              <% couriers.forEach(function(c) { %>
                <option value="<%= c.CourierName %>"><%= c.CourierName %></option>
              <% }) %>
            </select>
          </div>
          <div class="wh-form-row-inline">
            <div class="wh-form-row">
              <label for="wh_awb">AWB No.</label>
              <input type="text" id="wh_awb" name="awb" placeholder="AWB number">
            </div>
            <div class="wh-form-row">
              <label for="wh_dispatch_date">Dispatch Date</label>
              <input type="date" id="wh_dispatch_date" name="dispatch_date">
            </div>
          </div>
          <div class="wh-form-row">
            <label for="wh_remarks">Remarks</label>
            <textarea id="wh_remarks" name="warehouse_remarks" placeholder="Warehouse remarks…"></textarea>
          </div>
          <div class="wh-form-row">
            <label>WH Attachment</label>
            <div id="whExistingAttach" class="existing-attach hidden">
              <span id="whExistingLabel">Existing attachment</span>
              <button type="button" class="btn-view-existing" id="whViewExistingBtn">👁 View</button>
            </div>
            <div class="attach-options">
              <label class="attach-btn" for="wh_attach_file_transfer">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor">
                  <path d="M14 2H6c-1.1 0-2 .9-2 2v16c0 1.1.9 2 2 2h12c1.1 0 2-.9 2-2V8l-6-6zm2 16H8v-2h8v2zm0-4H8v-2h8v2zm-3-5V3.5L18.5 9H13z"/>
                </svg>
                Upload New
                <input type="file" id="wh_attach_file_transfer" name="wh_attachment_transfer"
                       accept=".jpg,.jpeg,.png,.pdf,.doc,.docx,.xls,.xlsx">
              </label>
            </div>
            <div id="whTransferPreviewWrap" class="preview-wrap hidden">
              <img id="whTransferPreviewImg" class="file-preview-img" src="" alt="Preview">
              <span id="whTransferFileLabel" class="file-name-label">No file chosen</span>
              <button type="button" class="clear-attach-btn" id="clearWhTransferAttach">✕</button>
            </div>
          </div>
          <div id="whTransferError" class="modal-error hidden"></div>
        </div>
        <div class="modal-footer">
          <button type="button" class="btn-secondary" id="saveWhDraftBtn">Save Draft</button>
          <button type="submit" class="btn-primary btn-warehouse" id="sendToWarehouseBtn">Send to Warehouse</button>
          <button type="button" class="btn-secondary" id="cancelWhTransferBtn">Cancel</button>
        </div>
      </form>
    </div>
  </div>

  <div id="storeAckModal" class="modal-overlay hidden">
    <div class="modal-box">
      <div class="modal-header">
        <span>Acknowledge & Receive</span>
        <button type="button" class="modal-close" id="closeStoreAckModal">✕</button>
      </div>
      <div class="modal-body">
        <p class="modal-job-id" id="storeAckJobId"></p>
        <p class="modal-confirm-text">Have you received the item back from the warehouse?</p>
      </div>
      <div class="modal-footer">
        <button class="btn-primary btn-warehouse" id="confirmStoreAckBtn">✓ Yes, Received</button>
        <button class="btn-secondary" id="cancelStoreAckBtn">Cancel</button>
      </div>
    </div>
  </div>
  <% } %>

  <!-- ════════════════════════════════════════
       WAREHOUSE MODALS
  ════════════════════════════════════════ -->
  <% if (isWarehouse) { %>
  <div id="whAckModal" class="modal-overlay hidden">
    <div class="modal-box">
      <div class="modal-header">
        <span>Acknowledge & Receive</span>
        <button type="button" class="modal-close" id="closeWhAckModal">✕</button>
      </div>
      <div class="modal-body">
        <p class="modal-job-id" id="whAckJobId"></p>
        <p class="modal-confirm-text">Do you acknowledge receipt of this item?</p>
      </div>
      <div class="modal-footer">
        <button class="btn-primary btn-warehouse" id="confirmWhAckBtn">✓ Yes, Acknowledge</button>
        <button class="btn-secondary" id="cancelWhAckBtn">Cancel</button>
      </div>
    </div>
  </div>

  <div id="sendVendorModal" class="modal-overlay hidden">
    <div class="modal-box modal-box-wh">
      <div class="modal-header">
        <span>Send to Vendor</span>
        <button type="button" class="modal-close" id="closeSendVendorModal">✕</button>
      </div>
      <div class="modal-body wh-modal-body">
        <p class="modal-job-id" id="sendVendorJobId"></p>
        <div class="wh-form-row">
          <label for="vendor_select">Select Vendor <span class="req">*</span></label>
          <select id="vendor_select" required>
            <option value="">Select Vendor</option>
            <% vendors.forEach(function(v) { %>
              <option value="<%= v.VendorID %> - <%= v.VendorName %>">
                <%= v.VendorID %> - <%= v.VendorName %>
              </option>
            <% }) %>
          </select>
        </div>
        <div class="wh-form-row-inline">
          <div class="wh-form-row">
            <label for="vendor_gate_pass">Gate Pass No.</label>
            <input type="text" id="vendor_gate_pass" placeholder="Gate pass number">
          </div>
          <div class="wh-form-row">
            <label for="vendor_sent_date">Date</label>
            <input type="date" id="vendor_sent_date">
          </div>
        </div>
        <div class="wh-form-row">
          <label for="vendor_awb">AWB No.</label>
          <input type="text" id="vendor_awb" placeholder="AWB number">
        </div>
        <div id="sendVendorError" class="modal-error hidden"></div>
      </div>
      <div class="modal-footer">
        <button class="btn-secondary" id="saveVendorDraftBtn" type="button">Save Draft</button>
        <button class="btn-primary btn-vendor" id="confirmSendVendorBtn">Send to Vendor</button>
        <button class="btn-secondary" id="cancelSendVendorBtn">Cancel</button>
      </div>
    </div>
  </div>

  <div id="vendorDecisionModal" class="modal-overlay hidden">
    <div class="modal-box">
      <div class="modal-header">
        <span>Vendor Decision</span>
        <button type="button" class="modal-close" id="closeVendorDecisionModal">✕</button>
      </div>
      <div class="modal-body">
        <p class="modal-job-id" id="vendorDecisionJobId"></p>
        <div class="wh-form-row">
          <label for="vendor_decision_select">Decision <span class="req">*</span></label>
          <select id="vendor_decision_select" required>
            <option value="">Select Decision</option>
            <option value="Repaired">Repaired</option>
            <option value="Replaced">Replaced</option>
          </select>
        </div>
        <div class="wh-form-row" style="margin-top:4px;">
          <label for="vendor_decision_date">Date <span class="req">*</span></label>
          <input type="date" id="vendor_decision_date" class="modal-input">
        </div>
        <div id="vendorDecisionError" class="modal-error hidden"></div>
      </div>
      <div class="modal-footer">
        <button class="btn-primary" id="confirmVendorDecisionBtn">Confirm Decision</button>
        <button class="btn-secondary" id="cancelVendorDecisionBtn">Cancel</button>
      </div>
    </div>
  </div>

  <div id="returnStoreModal" class="modal-overlay hidden">
    <div class="modal-box">
      <div class="modal-header">
        <span>Return to Store</span>
        <button type="button" class="modal-close" id="closeReturnStoreModal">✕</button>
      </div>
      <div class="modal-body">
        <p class="modal-job-id" id="returnStoreJobId"></p>
        <p class="modal-confirm-text">Do you want to return this item to the store?</p>
      </div>
      <div class="modal-footer">
        <button class="btn-primary btn-store" id="confirmReturnStoreBtn">✓ Yes, Return to Store</button>
        <button type="button" class="btn-secondary" id="cancelReturnStoreBtn">Cancel</button>
      </div>
    </div>
  </div>
  <% } %>

  <!-- ════════════════════════════════════════
       SHARED: DELIVERY DATE MODAL
  ════════════════════════════════════════ -->
  <div id="deliveryModal" class="modal-overlay hidden">
    <div class="modal-box">
      <div class="modal-header">
        <span>Update Delivery Date</span>
        <button type="button" class="modal-close" id="closeDeliveryModal">✕</button>
      </div>
      <div class="modal-body">
        <p class="modal-job-id" id="deliveryJobId"></p>
        <div class="wh-form-row">
          <label for="newDeliveryDate">New Delivery Date</label>
          <input type="date" id="newDeliveryDate" class="modal-input">
        </div>
      </div>
      <div class="modal-footer">
        <button class="btn-primary" id="saveDeliveryBtn">Save</button>
        <button class="btn-secondary" id="cancelDeliveryBtn">Cancel</button>
      </div>
    </div>
  </div>

  <!-- ════════════════════════════════════════
       SHARED: CLOSE TICKET WITH OTP
  ════════════════════════════════════════ -->
  <div id="closeTicketModal" class="modal-overlay hidden">
    <div class="modal-box" style="width:440px;">
      <div class="modal-header">
        <span>Close Ticket</span>
        <button type="button" class="modal-close" id="closeTicketModalBtn">✕</button>
      </div>
      <div class="modal-body">
        <p class="modal-job-id" id="closeJobId"></p>

        <div class="wh-form-row">
          <label for="closeRemarks">Closing Remarks <span class="req">*</span></label>
          <textarea id="closeRemarks" class="modal-textarea" placeholder="Enter closing remarks…"></textarea>
        </div>

        <div id="closeOtpSection" class="hidden">
          <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:8px;">
            <span style="font-size:12px;color:var(--text-mid);">OTP sent to <strong id="closeOtpPhone"></strong></span>
            <span id="closeOtpTimer">05:00</span>
          </div>
          <input type="text" id="closeOtpInput" maxlength="6" class="modal-input"
                 placeholder="● ● ● ● ● ●">
          <div id="closeOtpStatus"></div>
          <button type="button" id="closeResendOtpBtn" class="btn-secondary"
                  style="margin-top:8px;font-size:11px;padding:5px 14px;">
            Resend OTP
          </button>
        </div>

        <div id="closeTicketError" class="modal-error hidden"></div>
      </div>
      <div class="modal-footer">
        <button class="btn-primary btn-danger" id="confirmCloseBtn">Send OTP & Close</button>
        <button class="btn-secondary" id="cancelCloseBtn">Cancel</button>
      </div>
    </div>
  </div>

  <script>
    window.USER_ROLE = "<%= (role || '').toLowerCase().trim() %>";
  </script>
  <script src="/js/dashboard.js"></script>
  <script src="/js/action-analytics.js"></script>
</body>
</html>
